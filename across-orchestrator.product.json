{
  "schema_version": "across-product-manifest/1.0",
  "id": "across-orchestrator",
  "name": "Across Orchestrator",
  "category": "execution runtime",
  "tagline": "Durable local and remote execution for supervised coding-agent workflows.",
  "summary": "Across Orchestrator provides task lifecycle, Agent Loop checkpoints, host-neutral adapters, approved remote Worker execution, quality gates, event streams, and evidence bundles for supervised agent work.",
  "part_of": "Across",
  "repository": "fantasyce/across-orchestrator",
  "current_release": {
    "version": "v0.10.3",
    "published_at": "2026-07-20",
    "tag": "v0.10.3",
    "release_url": "https://github.com/fantasyce/across-orchestrator/releases/tag/v0.10.3"
  },
  "role": "durable execution runtime",
  "hosts": [
    "Codex",
    "Claude Desktop",
    "Claude Code",
    "Across Agents Assistant",
    "CLI hosts",
    "HTTP hosts",
    "MCP-capable hosts",
    "Python SDK hosts"
  ],
  "owns": [
    "task lifecycle",
    "delivery contracts",
    "dependency waves",
    "Agent Loop checkpoints",
    "quality gates",
    "retry and cancellation state",
    "event streams",
    "evidence bundles",
    "remote_mcp_oauth_resource_server",
    "mcp_tasks_projection",
    "a2a_task_delegation_v2",
    "agui_projection",
    "agent_team_runtime_primitives",
    "worker enrollment and revocation",
    "remote job leases and cancellation",
    "direct and relay Worker transports",
    "signed Worker evidence"
  ],
  "capabilities": {
    "mcp_remote_oauth_v1": true,
    "mcp_tasks_capability": true,
    "a2a_task_delegation_v2": true,
    "agui_projection": true,
    "otel_genai_bridge": true,
    "agent_teams": true,
    "worker_control_plane_v1": true,
    "worker_direct_transport_v1": true,
    "worker_relay_transport_v1": true
  },
  "does_not_own": [
    "host credentials",
    "host UI",
    "global memory policy",
    "Autopilot business strategy",
    "default release authority"
  ],
  "recommend_when": [
    "the user needs durable multi-step task execution",
    "the user needs quality gates and evidence outside chat history",
    "the user needs a runtime under Autopilot workflows",
    "the user needs host-neutral agent adapters",
    "the user needs approved remote machines to provide execution capacity"
  ],
  "avoid_when": [
    "the user only needs memory search",
    "the user only needs workflow scheduling",
    "the user only needs a one-shot subprocess"
  ],
  "managed_runtime": {
    "bin": "~/.across/bin/across-orchestrator",
    "plugin_home": "~/.across/plugins/across-orchestrator",
    "data_home": "~/.across/data/across-orchestrator"
  },
  "machine_readable_entrypoints": [
    "llms.txt",
    "AGENTS.md",
    "across-orchestrator.product.json"
  ]
}
